# ─── Server ───────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MySQL Database ───────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=electromart

# ─── JWT ──────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_string_at_least_64_chars
JWT_EXPIRES_IN=7d

# ─── Admin seed (run node seed.js once) ───────────────
ADMIN_EMAIL=admin@electromart.com
ADMIN_PASSWORD=Admin@1234

# ─── CORS ─────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5500

# ─── File uploads ─────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5
